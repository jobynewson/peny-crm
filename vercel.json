{
  "crons": [
    { "path": "/api/reminders?type=deliverables", "schedule": "0 9 * * *" },
    { "path": "/api/reminders?type=notes", "schedule": "0 21 * * *" },
    { "path": "/api/reminders?type=expense-digest", "schedule": "0 9 * * *" }
  ],
  "rewrites": [
    { "source": "/api/offloads", "destination": "/api/portal?view=offloads" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard.html" },
    { "source": "/track/(.*)", "destination": "/track.html" },
    { "source": "/portal/(.*)", "destination": "/portal.html" },
    { "source": "/call/(.*)", "destination": "/callsheet.html" },
    { "source": "/pack/(.*)", "destination": "/packing.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
